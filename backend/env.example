PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/travelbuddy
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
EMAIL_FROM="Travel Buddy <hello@travelbuddy.com>"

# Khalti Payment Gateway
KHALTI_SECRET_KEY=your_khalti_live_or_test_secret_key
FRONTEND_URL=http://localhost:5173

# Allow Vercel preview deployments in CORS/Socket.IO (set true on Render if needed)
ALLOW_VERCEL_PREVIEWS=false

# Recaptcha
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Hugging Face API Token for Mistral-7B-Instruct-v0.2 model
HF_TOKEN=your_huggingface_token_here

# Gemini API key for itinerary generation (optional; app runs in demo mode if missing)
GEMINI_API_KEY=your_gemini_api_key

# Cloudinary (required for photo uploads / chat attachments)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
