PORT=5000
# Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/travelbuddy

# MongoDB Atlas (recommended: include db name in the URI):
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/travelbuddy?retryWrites=true&w=majority&appName=<appName>

# Optional: only needed if your MONGO_URI does NOT include a /dbName segment.
# If omitted, the backend defaults to: travelbuddy
# MONGO_DB_NAME=travelbuddy
JWT_SECRET=your_jwt_secret_here
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
EMAIL_FROM="Travel Buddy <hello@travelbuddy.com>"

# Khalti Sandbox Payment
KHALTI_SANDBOX_SECRET=your_khalti_sandbox_secret_key_here

FRONTEND_URL=http://localhost:5173

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Recaptcha
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Groq API Configuration for Itinerary Generator (FREE - No credit card needed!)
# Get your free API key from https://console.groq.com/keys
# Available models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
